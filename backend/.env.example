FLASK_ENV=development
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION_HOURS=24

# MySQL connection string
MYSQL_DATABASE_URI=mysql+pymysql://root:password@localhost/statistikita_db

# Gemini API (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Optional: override base URL if needed
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend URL (used for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:3000

# DB pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Upload and payload limits (bytes)
MAX_CONTENT_LENGTH=16777216
MAX_AVATAR_SIZE=2097152
MAX_FORUM_FILE_SIZE=10485760
MAX_PDF_SIZE=20971520
MAX_CHAT_MESSAGE_LENGTH=2000

# Server port
PORT=5000
